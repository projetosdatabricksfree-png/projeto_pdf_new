{
    "id": "digital_print_standard",
    "name": "Digital Print Standard",
    "description": "Agressivo para impressoras digitais: TAC 320%, DPI minimo 150. Aplica fixes automaticos onde possivel.",
    "rules": {
        "color_space": {
            "enabled": true,
            "severity": "ERROR",
            "params": {}
        },
        "page_size": {
            "enabled": true,
            "severity": "ERROR",
            "params": {}
        },
        "bleed": {
            "enabled": true,
            "severity": "ERROR",
            "params": {}
        },
        "resolution": {
            "enabled": true,
            "severity": "WARNING",
            "params": {
                "threshold_dpi": "200",
                "error_dpi": "150"
            }
        },
        "safety_margin": {
            "enabled": true,
            "severity": "WARNING",
            "params": {}
        },
        "transparency": {
            "enabled": true,
            "severity": "WARNING",
            "params": {}
        },
        "tac": {
            "enabled": true,
            "severity": "ERROR",
            "params": {
                "max_tac_percent": "320"
            }
        },
        "output_intent": {
            "enabled": true,
            "severity": "ERROR",
            "params": {}
        },
        "white_overprint": {
            "enabled": true,
            "severity": "ERROR",
            "params": {}
        },
        "black_consistency": {
            "enabled": true,
            "severity": "WARNING",
            "params": {}
        },
        "annotations": {
            "enabled": true,
            "severity": "WARNING",
            "params": {}
        },
        "layers": {
            "enabled": true,
            "severity": "WARNING",
            "params": {}
        },
        "spot_colors": {
            "enabled": true,
            "severity": "WARNING",
            "params": {}
        },
        "rotation": {
            "enabled": true,
            "severity": "WARNING",
            "params": {}
        }
    }
}
