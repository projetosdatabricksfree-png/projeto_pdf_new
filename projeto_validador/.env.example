# === Database ===
# Dev: SQLite
DATABASE_URL=sqlite+aiosqlite:///./validador.db
# Prod: PostgreSQL
# DATABASE_URL=postgresql+asyncpg://user:password@db:5432/validador

# === Redis / Celery ===
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# === LLM (reservado para uso futuro) ===
LLM_API_KEY=sk-ant-placeholder

# === Storage ===
VOLUME_PATH=./volumes/uploads

# === App ===
APP_ENV=development
LOG_LEVEL=INFO
